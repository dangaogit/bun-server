---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const categories = [
  {
    id: '00-quick-start',
    iconImage: '/favicon.svg',
    label: '快速开始',
    desc: '5 分钟快速运行',
    examples: [
      { name: 'Hello World', file: '01-hello-world.ts', desc: '5 行启动 HTTP 服务' },
      { name: '基础路由', file: '02-basic-routing.ts', desc: 'GET/POST/PUT/DELETE 路由' },
      { name: '依赖注入', file: '03-dependency-injection.ts', desc: '@Injectable + 构造函数注入' },
    ],
  },
  {
    id: '02-official-modules',
    label: '📦 官方模块',
    desc: '开箱即用的框架模块',
    examples: [
      { name: '认证 (JWT + OAuth2)', file: 'auth-app.ts', desc: 'SecurityModule' },
      { name: '数据库 + ORM', file: 'orm-app.ts', desc: 'DatabaseModule + Entity/Repository' },
      { name: '缓存', file: 'cache-app.ts', desc: 'CacheModule + TTL' },
      { name: '队列 + Cron', file: 'queue-app.ts', desc: 'QueueModule 异步任务' },
      { name: '事件系统', file: 'events-app.ts', desc: 'EventModule + @OnEvent()' },
      { name: '指标监控', file: 'metrics-rate-limit-app.ts', desc: 'MetricsModule + RateLimit' },
    ],
  },
  {
    id: '05-ai',
    label: '🤖 AI 模块',
    desc: 'v2.0.0 — 9 个官方 AI 模块',
    highlight: true,
    examples: [
      { name: '基础对话', file: '01-basic-chat.ts', desc: '多 Provider LLM 对话' },
      { name: '流式响应', file: '02-streaming-chat.ts', desc: 'SSE 流式输出' },
      { name: 'Tool Calling', file: '03-tool-calling.ts', desc: '@AiTool() + 函数调用循环' },
      { name: '会话记忆', file: '04-conversation-memory.ts', desc: '多轮历史管理' },
      { name: 'Prompt 模板', file: '05-prompt-templates.ts', desc: '{{variable}} 模板 + 版本管理' },
      { name: 'RAG 管道', file: '06-rag-pipeline.ts', desc: '文档 -> 向量化 -> 检索 -> 回答' },
      { name: 'MCP 服务端', file: '07-mcp-server.ts', desc: 'Model Context Protocol 服务端' },
      { name: 'AI Guard', file: '08-ai-guard.ts', desc: 'PII + 注入检测 + 内容审核' },
      { name: 'AI 平台 MVP', file: 'ai-platform-mvp/', desc: '完整 AI 中台示例' },
    ],
  },
];
---

<BaseLayout title="示例" description="Bun Server Framework 示例应用">
  <div class="mx-auto max-w-7xl px-6 py-12">
    <div class="mb-12 text-center">
      <h1 class="text-4xl font-bold text-white">示例</h1>
      <p class="mt-3 text-zinc-400">
        通过示例快速学习。全部示例可在
        <a href="https://github.com/dangaogit/bun-server/tree/main/examples" class="text-brand-400 hover:text-brand-300">
          GitHub 仓库
        </a>
        查看。
      </p>
    </div>

    <div class="space-y-12">
      {categories.map((cat) => (
        <div>
          <div class="mb-4 flex items-center gap-3">
            {cat.iconImage && <img src={cat.iconImage} alt="bun-server logo" class="h-5 w-5" />}
            <h2 class="text-xl font-bold text-white">{cat.label}</h2>
            {cat.highlight && (
              <span class="rounded-full bg-brand-500/20 px-3 py-0.5 text-xs font-semibold text-brand-300">NEW v2.0</span>
            )}
          </div>
          <p class="mb-4 text-sm text-zinc-400">{cat.desc}</p>
          <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
            {cat.examples.map((ex) => (
              <div class:list={[
                'rounded-xl border p-5 transition-colors',
                cat.highlight
                  ? 'border-brand-900/50 bg-brand-950/20 hover:border-brand-700/50'
                  : 'border-zinc-800 bg-zinc-900 hover:border-zinc-700',
              ]}>
                <h3 class="font-semibold text-white">{ex.name}</h3>
                <p class="mt-1 text-sm text-zinc-400">{ex.desc}</p>
                <code class:list={[
                  'mt-2 block font-mono text-xs',
                  cat.highlight ? 'text-brand-400' : 'text-zinc-500',
                ]}>
                  {cat.id}/{ex.file}
                </code>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</BaseLayout>
