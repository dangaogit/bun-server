---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const versions = [
  {
    version: 'v3.0.0',
    date: '2026-04',
    tag: 'latest',
    highlight: true,
    changes: [
      { type: 'feat', text: 'Platform Adapter Layer — Bun 与 Node.js 22+ 透明多运行时支持' },
      { type: 'feat', text: '六大适配器契约：IFsAdapter、ICryptoAdapter、IParserAdapter、IProcessAdapter、IHttpDriver、IWebSocket<T>' },
      { type: 'feat', text: 'BunPlatform：封装 Bun.file/write/Glob、Bun.CryptoHasher、Bun.JSONC/JSON5/markdown、Bun.serve、Bun.ServerWebSocket' },
      { type: 'feat', text: 'NodePlatform：使用 node:fs、node:crypto、jsonc-parser/json5/marked、node:http、node:child_process、ws' },
      { type: 'feat', text: 'resolvePlatform() 优先级链：ApplicationOptions.platform > --platform CLI > BUN_SERVER_PLATFORM env > 自动检测' },
      { type: 'feat', text: '从 @dangao/bun-server 导出 getRuntime() / initRuntime() 单例访问器' },
      { type: 'feat', text: 'DatabaseModule 自动感知运行时，在 bun:sqlite/Bun.SQL 与 better-sqlite3/postgres/mysql2 间切换，无需额外配置' },
      { type: 'feat', text: '新增 dist/index.node.mjs 与 "node" 导出条件，生成纯 Node.js 兼容 bundle' },
      { type: 'feat', text: '新增 examples/06-platform/：自动检测、显式 Node.js、CLI 切换三个示例' },
      { type: 'test', text: '平台共享测试套件（bun:test + vitest）覆盖 fs/crypto/parser/process/websocket/database 适配器' },
      { type: 'docs', text: '新增 docs/platform.md 和 docs/zh/platform.md；README 新增 Node.js 徽章和架构图' },
      { type: 'chore', text: '新增 jsonc-parser、json5、marked、mime-types、ws、postgres、mysql2、better-sqlite3 运行时依赖' },
      { type: 'chore', text: '将 @dangao/bun-server 与 @dangao/bun-server-web 升级到 3.0.0，并同步 web changelog 页面' },
    ],
  },
  {
    version: 'v2.3.0',
    date: '2026-03',
    tag: '',
    highlight: false,
    changes: [
      { type: 'feat', text: '自动检测 SSE 响应，通过 server.timeout(req, 0) 禁用 Bun TCP 空闲超时' },
      { type: 'feat', text: '按可配置间隔注入 SSE 心跳（: keepalive），防止中间代理断连' },
      { type: 'feat', text: 'ApplicationOptions 新增 sseKeepAlive 配置（enabled、intervalMs）' },
      { type: 'feat', text: 'Context 暴露 ctx.signal（AbortSignal），支持客户端断连级联取消' },
      { type: 'feat', text: 'AiRequest 新增 signal 字段 — 4 个 Provider 的 stream()/complete() 均透传 abort 信号至上游 AI API' },
      { type: 'refactor', text: '移除 McpServer SSE 手动 setInterval ping — 由框架 SSE 后处理器统一接管' },
      { type: 'docs', text: '重写 idle-timeout 文档：双层超时机制说明、SSE 保活配置、ctx.signal 级联指南' },
      { type: 'feat', text: 'idle-timeout-app.ts 示例新增 SSE 端点，演示自动保活与信号级联' },
      { type: 'chore', text: '将 @dangao/bun-server 与 @dangao/bun-server-web 升级到 2.3.0，并同步 web changelog 页面' },
    ],
  },
  {
    version: 'v2.2.0',
    date: '2026-03',
    tag: '',
    highlight: false,
    changes: [
      { type: 'feat', text: '为 @Controller/@Injectable 新增组件生命周期钩子：onBeforeCreate/onAfterCreate/onBeforeDestroy/onAfterDestroy' },
      { type: 'feat', text: '对齐 controller 与 provider 的模块启动/关闭生命周期执行链路' },
      { type: 'feat', text: '请求结束时自动清理 Lifecycle.Scoped 实例，并触发 scoped 销毁钩子' },
      { type: 'feat', text: '增强 examples/01-core-features/lifecycle-app.ts，新增 /api/scoped 请求级生命周期演示' },
      { type: 'docs', text: '更新 lifecycle 文档与测试，覆盖钩子顺序与 scoped 清理行为' },
    ],
  },
  {
    version: 'v2.1.0',
    date: '2026-03',
    tag: '',
    highlight: false,
    changes: [
      { type: 'feat', text: '引入 Bun.SQL manager、sqlite adapter、ALS 会话上下文、db proxy 以及路由级数据库策略装饰器' },
      { type: 'refactor', text: '事务管理迁移为基于 ALS 的状态模型，统一 db.transaction() 与 @Transactional 语义' },
      { type: 'fix', text: '去重 provider 实例，避免 onModuleInit 被重复执行' },
      { type: 'feat', text: '新增 ServiceRegistryModule.autoRegister 开关，并在 Application 中加入 listen 时机保护' },
      { type: 'feat', text: '支持全局 idleTimeout 与路由级 @IdleTimeout(ms)，超时返回 408' },
      { type: 'docs', text: '更新 database/lifecycle/microservice 文档，并新增 docs/idle-timeout.md 与 docs/zh/idle-timeout.md' },
      { type: 'test', text: '新增并补齐数据库策略、db proxy、sqlite adapter、SQL manager、生命周期去重与超时场景测试覆盖' },
      { type: 'feat', text: '刷新 database-app.ts 示例，并新增 nacos-auto-register-app.ts 与 idle-timeout-app.ts' },
      { type: 'chore', text: '将 @dangao/bun-server 与 @dangao/bun-server-web 升级到 2.1.0，并同步 web changelog 页面' },
    ],
  },
  {
    version: 'v2.0.8',
    date: '2026-03',
    tag: '',
    highlight: false,
    changes: [
      { type: 'fix', text: 'DatabaseService 改为通过 Bun.SQL 模板 values 绑定参数，并保留原始查询错误上下文' },
      { type: 'refactor', text: '统一替换 src 下 catch 无异常绑定写法，提升错误处理一致性' },
      { type: 'feat', text: 'examples/04-real-world 数据库测试页支持自定义 SQL 输入' },
      { type: 'test', text: '补充 Bun.SQL 占位符与参数绑定路径的回归测试' },
      { type: 'chore', text: '将 @dangao/bun-server 与 @dangao/bun-server-web 版本统一升级到 2.0.8，并同步 changelog 页面' },
    ],
  },
  {
    version: 'v2.0.4',
    date: '2026-03',
    tag: '',
    highlight: false,
    changes: [
      { type: 'feat', text: '新增 createErrorResponse，仅用于错误响应路径并自动过滤敏感字段' },
      { type: 'fix', text: '增强错误响应安全性，避免在返回体中泄露 stack/trace/cause' },
      { type: 'chore', text: '删除未使用的 release workflow，并将 packages/web 版本升级到 2.0.4' },
      { type: 'test', text: '补充响应脱敏与兼容性回归测试覆盖' },
    ],
  },
  {
    version: 'v2.0.3',
    date: '2026-03',
    tag: '',
    highlight: false,
    changes: [
      { type: 'fix', text: '修复 examples/deploy 中 WebSocket 升级代理转发，确保 wss 流量正确透传' },
      { type: 'fix', text: '修复 WebSocket 示例在 HTTPS 页面下自动切换 wss:// 协议' },
      { type: 'docs', text: '将 playground 文案统一为 examples，保持示例入口命名一致' },
      { type: 'chore', text: '同步 web 中英文 changelog 页面，并将 packages/web 版本更新为 2.0.3' },
    ],
  },
  {
    version: 'v2.0.0',
    date: '2026-03',
    tag: '',
    highlight: false,
    changes: [
      { type: 'feat', text: 'AiModule — 统一 LLM 接入（OpenAI、Claude、Gemini、Ollama）+ Tool Calling + 流式响应' },
      { type: 'feat', text: 'ConversationModule — 多轮会话记忆（Memory/Redis/Database 存储）' },
      { type: 'feat', text: 'PromptModule — 支持变量插值与版本管理的 Prompt 模板系统' },
      { type: 'feat', text: 'EmbeddingModule — 文本向量生成（OpenAI、Ollama）' },
      { type: 'feat', text: 'VectorStoreModule — 向量相似检索（Memory、Pinecone、Qdrant）' },
      { type: 'feat', text: 'RagModule — 完整 RAG 管道（TextChunker + MarkdownChunker）' },
      { type: 'feat', text: 'McpModule — MCP 协议服务端（JSON-RPC 2.0，SSE 传输）' },
      { type: 'feat', text: 'AiGuardModule — PII 检测、Prompt 注入检测、内容审核' },
      { type: 'feat', text: 'AI 平台 MVP 示例 — 完整 AI 中台能力演示' },
      { type: 'feat', text: 'packages/web — 宣传门户网站（Astro + Tailwind CSS）' },
      { type: 'docs', text: '新增 docs/ai.md，完整覆盖 9 个 AI 官方模块' },
    ],
  },
  {
    version: 'v1.9.0',
    date: '2025-11',
    tag: '',
    highlight: false,
    changes: [
      { type: 'feat', text: 'EventModule — @OnEvent() 在 app.listen() 自动扫描，无需手动 initializeListeners()' },
      { type: 'feat', text: 'Guards 系统 — 支持 @UseGuards() 自定义守卫' },
      { type: 'fix', text: '修复多项问题并提升性能' },
    ],
  },
  {
    version: 'v1.8.0',
    date: '2025-08',
    tag: '',
    highlight: false,
    changes: [
      { type: 'feat', text: 'DashboardModule — 内置监控 Web UI' },
      { type: 'feat', text: 'DebugModule — HTTP 请求录制与重放' },
      { type: 'feat', text: 'ClusterManager — 零配置多进程集群' },
    ],
  },
];

const typeColors: Record<string, string> = {
  feat: 'text-brand-400 bg-brand-500/10',
  fix: 'text-green-400 bg-green-500/10',
  refactor: 'text-amber-400 bg-amber-500/10',
  docs: 'text-blue-400 bg-blue-500/10',
  chore: 'text-zinc-400 bg-zinc-800',
  test: 'text-purple-400 bg-purple-500/10',
};
---

<BaseLayout title="更新日志" description="Bun Server Framework 版本历史">
  <div class="mx-auto max-w-3xl px-6 py-12">
    <h1 class="mb-12 text-4xl font-bold text-white">更新日志</h1>

    <div class="space-y-12">
      {versions.map((v) => (
        <div>
          <div class="mb-4 flex items-center gap-3">
            <h2 class:list={[
              'text-2xl font-bold',
              v.highlight ? 'text-brand-300' : 'text-white',
            ]}>
              {v.version}
            </h2>
            {v.tag && (
              <span class="rounded-full bg-brand-500/20 px-3 py-0.5 text-xs font-semibold text-brand-300">
                {v.tag}
              </span>
            )}
            <span class="text-sm text-zinc-500">{v.date}</span>
          </div>

          <ul class="space-y-2">
            {v.changes.map((change) => (
              <li class="flex items-start gap-3">
                <span class:list={[
                  'mt-0.5 shrink-0 rounded px-1.5 py-0.5 font-mono text-xs font-semibold',
                  typeColors[change.type] ?? 'text-zinc-400 bg-zinc-800',
                ]}>
                  {change.type}
                </span>
                <span class="text-sm text-zinc-300">{change.text}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</BaseLayout>
