---
import BaseLayout from '../../layouts/BaseLayout.astro';

const versions = [
  {
    version: 'v3.0.3',
    date: '2026-04',
    tag: 'latest',
    highlight: true,
    changes: [
      { type: 'fix', text: 'Move ws from dependencies to peerDependencies (optional: true) — no longer installed automatically' },
      { type: 'fix', text: 'setupWebSocket() throws a clear install instruction when ws is missing: "bun add ws"' },
    ],
  },
  {
    version: 'v3.0.2',
    date: '2026-04',
    tag: '',
    highlight: false,
    changes: [
      { type: 'refactor', text: 'Move @vscode/sqlite3 from dependencies to peerDependencies (optional: true) — no longer installed automatically' },
      { type: 'refactor', text: 'SqliteAdapter and ConnectionPool throw a clear install instruction when @vscode/sqlite3 is missing' },
    ],
  },
  {
    version: 'v3.0.1',
    date: '2026-04',
    tag: '',
    highlight: false,
    changes: [
      { type: 'fix', text: 'Replace better-sqlite3 with @vscode/sqlite3 5.1.12-vscode as the Node.js SQLite driver' },
      { type: 'fix', text: 'SqliteAdapter.query() is now async — Node.js path uses @vscode/sqlite3 callback-based db.all() wrapped in a Promise' },
      { type: 'fix', text: 'DatabaseService.querySqlite() adds async branch for @vscode/sqlite3 connections' },
      { type: 'fix', text: 'ConnectionManager.healthCheckSqlite() adds async health-check path for @vscode/sqlite3' },
      { type: 'chore', text: 'Remove better-sqlite3 / @types/better-sqlite3; add @vscode/sqlite3@5.1.12-vscode' },
      { type: 'chore', text: 'Add --external @vscode/sqlite3 to bundle script — native addon cannot be inlined by bun build' },
    ],
  },
  {
    version: 'v3.0.0',
    date: '2026-04',
    tag: '',
    highlight: false,
    changes: [
      { type: 'feat', text: 'Platform Adapter Layer — transparent multi-runtime support for Bun and Node.js 22+' },
      { type: 'feat', text: 'Six adapter contracts: IFsAdapter, ICryptoAdapter, IParserAdapter, IProcessAdapter, IHttpDriver, IWebSocket<T>' },
      { type: 'feat', text: 'BunPlatform: wraps Bun.file/write/Glob, Bun.CryptoHasher, Bun.JSONC/JSON5/markdown, Bun.serve, Bun.ServerWebSocket' },
      { type: 'feat', text: 'NodePlatform: uses node:fs, node:crypto, jsonc-parser/json5/marked, node:http, node:child_process, ws' },
      { type: 'feat', text: 'resolvePlatform() priority chain: ApplicationOptions.platform > --platform CLI > BUN_SERVER_PLATFORM env > auto-detect' },
      { type: 'feat', text: 'Export getRuntime() / initRuntime() singleton accessor from @dangao/bun-server' },
      { type: 'feat', text: 'DatabaseModule auto-selects bun:sqlite/Bun.SQL or better-sqlite3/postgres/mysql2 based on detected runtime' },
      { type: 'feat', text: 'Add dist/index.node.mjs with "node" export condition for clean Node.js-compatible bundle' },
      { type: 'feat', text: 'Add examples/06-platform/ — auto-detect, explicit Node.js, and CLI-switch examples' },
      { type: 'test', text: 'Shared platform test suites (bun:test + vitest) covering fs/crypto/parser/process/websocket/database adapters' },
      { type: 'docs', text: 'Add docs/platform.md and docs/zh/platform.md; update README with Node.js badge and architecture diagram' },
      { type: 'chore', text: 'Add jsonc-parser, json5, marked, mime-types, ws, postgres, mysql2, better-sqlite3 as runtime dependencies' },
      { type: 'chore', text: 'Bump @dangao/bun-server and @dangao/bun-server-web to 3.0.0 and sync web changelog pages' },
    ],
  },
  {
    version: 'v2.3.0',
    date: '2026-03',
    tag: '',
    highlight: false,
    changes: [
      { type: 'feat', text: 'Auto-detect SSE responses and disable Bun TCP idle timeout via server.timeout(req, 0)' },
      { type: 'feat', text: 'Inject SSE heartbeat (: keepalive) at configurable interval to prevent proxy disconnects' },
      { type: 'feat', text: 'Add sseKeepAlive configuration to ApplicationOptions (enabled, intervalMs)' },
      { type: 'feat', text: 'Expose ctx.signal (AbortSignal) on Context for client disconnect cascading' },
      { type: 'feat', text: 'Add signal field to AiRequest — propagate abort to upstream AI API fetch calls across all 4 providers' },
      { type: 'refactor', text: 'Remove manual setInterval ping from McpServer SSE — now handled by framework SSE post-processor' },
      { type: 'docs', text: 'Rewrite idle-timeout docs with two-layer timeout explanation, SSE keep-alive config, and ctx.signal guide' },
      { type: 'feat', text: 'Add SSE endpoint to idle-timeout-app.ts example demonstrating auto keep-alive and signal cascading' },
      { type: 'chore', text: 'Bump @dangao/bun-server and @dangao/bun-server-web to 2.3.0 and sync web changelog pages' },
    ],
  },
  {
    version: 'v2.2.0',
    date: '2026-03',
    tag: '',
    highlight: false,
    changes: [
      { type: 'feat', text: 'Add component lifecycle hooks for @Controller/@Injectable: onBeforeCreate/onAfterCreate/onBeforeDestroy/onAfterDestroy' },
      { type: 'feat', text: 'Align controller lifecycle execution with providers during module startup/shutdown' },
      { type: 'feat', text: 'Auto-dispose Lifecycle.Scoped instances at request end and invoke scoped destroy hooks' },
      { type: 'feat', text: 'Enhance examples/01-core-features/lifecycle-app.ts with /api/scoped request-scoped lifecycle demo' },
      { type: 'docs', text: 'Update lifecycle docs and tests for hook ordering and scoped cleanup behavior' },
    ],
  },
  {
    version: 'v2.1.0',
    date: '2026-03',
    tag: '',
    highlight: false,
    changes: [
      { type: 'feat', text: 'Introduce Bun.SQL manager, sqlite adapter, ALS session context, db proxy, and route-level database strategy decorators' },
      { type: 'refactor', text: 'Migrate transaction manager to ALS-based state and unify db.transaction() with @Transactional' },
      { type: 'fix', text: 'Deduplicate provider instances to prevent duplicate onModuleInit execution' },
      { type: 'feat', text: 'Add ServiceRegistryModule.autoRegister switch and listen-time guard in Application' },
      { type: 'feat', text: 'Support global idleTimeout and route-level @IdleTimeout(ms) with 408 timeout response' },
      { type: 'docs', text: 'Update database/lifecycle/microservice docs and add docs/idle-timeout.md + docs/zh/idle-timeout.md' },
      { type: 'test', text: 'Add and refresh coverage for database strategy, db proxy, sqlite adapter, SQL manager, lifecycle dedup, and timeout scenarios' },
      { type: 'feat', text: 'Refresh database-app.ts and add nacos-auto-register-app.ts + idle-timeout-app.ts examples' },
      { type: 'chore', text: 'Bump @dangao/bun-server and @dangao/bun-server-web to 2.1.0 and sync web changelog pages' },
    ],
  },
  {
    version: 'v2.0.8',
    date: '2026-03',
    tag: '',
    highlight: false,
    changes: [
      { type: 'fix', text: 'Use Bun.SQL template value binding in DatabaseService and preserve original query error context' },
      { type: 'refactor', text: 'Replace catch-without-binding patterns across src to improve error handling consistency' },
      { type: 'feat', text: 'Add custom SQL input support in examples/04-real-world database test app' },
      { type: 'test', text: 'Add regression tests for Bun.SQL placeholder/parameter binding paths' },
      { type: 'chore', text: 'Bump @dangao/bun-server and @dangao/bun-server-web to 2.0.8 and sync changelog pages' },
    ],
  },
  {
    version: 'v2.0.4',
    date: '2026-03',
    tag: '',
    highlight: false,
    changes: [
      { type: 'feat', text: 'Add createErrorResponse for error-only response paths with sensitive field redaction' },
      { type: 'fix', text: 'Harden default error responses to avoid leaking stack/trace/cause in API payloads' },
      { type: 'chore', text: 'Remove the unused release workflow and bump packages/web version to 2.0.4' },
      { type: 'test', text: 'Add regression coverage for response redaction and compatibility behavior' },
    ],
  },
  {
    version: 'v2.0.3',
    date: '2026-03',
    tag: '',
    highlight: false,
    changes: [
      { type: 'fix', text: 'Fix websocket upgrade proxying in examples/deploy to correctly forward wss traffic' },
      { type: 'fix', text: 'Fix websocket example to use wss:// automatically on HTTPS pages' },
      { type: 'docs', text: 'Rename playground references to examples for a unified examples experience' },
      { type: 'chore', text: 'Sync web changelog pages and bump packages/web version to 2.0.3' },
    ],
  },
  {
    version: 'v2.0.0',
    date: '2026-03',
    tag: '',
    highlight: false,
    changes: [
      { type: 'feat', text: 'AiModule — LLM unified access (OpenAI, Claude, Gemini, Ollama) + Tool Calling + streaming' },
      { type: 'feat', text: 'ConversationModule — Multi-turn conversation memory (Memory/Redis/Database stores)' },
      { type: 'feat', text: 'PromptModule — Prompt template management with versioning and variable interpolation' },
      { type: 'feat', text: 'EmbeddingModule — Text embedding generation (OpenAI, Ollama)' },
      { type: 'feat', text: 'VectorStoreModule — Vector similarity search (Memory, Pinecone, Qdrant)' },
      { type: 'feat', text: 'RagModule — Full RAG pipeline with TextChunker and MarkdownChunker' },
      { type: 'feat', text: 'McpModule — MCP protocol server (JSON-RPC 2.0, SSE transport)' },
      { type: 'feat', text: 'AiGuardModule — PII detection, prompt injection detection, content moderation' },
      { type: 'feat', text: 'AI Platform MVP demo — Dify-comparable AI middleware platform example' },
      { type: 'feat', text: 'packages/web — Promotional portal site (Astro + Tailwind CSS)' },
      { type: 'docs', text: 'Comprehensive docs/ai.md covering all 9 AI modules' },
    ],
  },
  {
    version: 'v1.9.0',
    date: '2025-11',
    tag: '',
    highlight: false,
    changes: [
      { type: 'feat', text: 'EventModule — @OnEvent() auto-scans at app.listen(), no manual initializeListeners() needed' },
      { type: 'feat', text: 'Guards system — custom guards with @UseGuards() decorator' },
      { type: 'fix', text: 'Various bug fixes and performance improvements' },
    ],
  },
  {
    version: 'v1.8.0',
    date: '2025-08',
    tag: '',
    highlight: false,
    changes: [
      { type: 'feat', text: 'DashboardModule — embedded monitoring Web UI' },
      { type: 'feat', text: 'DebugModule — HTTP request recording and replay' },
      { type: 'feat', text: 'ClusterManager — zero-config multi-process clustering' },
    ],
  },
];

const typeColors: Record<string, string> = {
  feat: 'text-brand-400 bg-brand-500/10',
  fix: 'text-green-400 bg-green-500/10',
  refactor: 'text-amber-400 bg-amber-500/10',
  docs: 'text-blue-400 bg-blue-500/10',
  chore: 'text-zinc-400 bg-zinc-800',
  test: 'text-purple-400 bg-purple-500/10',
};
---

<BaseLayout title="Changelog" description="Bun Server Framework release history">
  <div class="mx-auto max-w-3xl px-6 py-12">
    <h1 class="mb-12 text-4xl font-bold text-white">Changelog</h1>

    <div class="space-y-12">
      {versions.map((v) => (
        <div>
          <div class="mb-4 flex items-center gap-3">
            <h2 class:list={[
              'text-2xl font-bold',
              v.highlight ? 'text-brand-300' : 'text-white',
            ]}>
              {v.version}
            </h2>
            {v.tag && (
              <span class="rounded-full bg-brand-500/20 px-3 py-0.5 text-xs font-semibold text-brand-300">
                {v.tag}
              </span>
            )}
            <span class="text-sm text-zinc-500">{v.date}</span>
          </div>

          <ul class="space-y-2">
            {v.changes.map((change) => (
              <li class="flex items-start gap-3">
                <span class:list={[
                  'mt-0.5 shrink-0 rounded px-1.5 py-0.5 font-mono text-xs font-semibold',
                  typeColors[change.type] ?? 'text-zinc-400 bg-zinc-800',
                ]}>
                  {change.type}
                </span>
                <span class="text-sm text-zinc-300">{change.text}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</BaseLayout>
