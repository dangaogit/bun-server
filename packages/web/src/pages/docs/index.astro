---
import BaseLayout from '../../layouts/BaseLayout.astro';

const docSections = [
  { href: '/docs/guide', title: 'Getting Started', desc: 'Quick start, project setup, minimal app' },
  { href: '/docs/api', title: 'API Reference', desc: 'Controllers, routing, middleware, DI' },
  { href: '/docs/ai', title: 'AI Modules', desc: '9 official AI modules — LLM, RAG, MCP, and more', highlight: true },
  { href: '/docs/testing', title: 'Testing Guide', desc: 'Test.createTestingModule(), test HTTP client' },
  { href: '/docs/microservice', title: 'Microservices', desc: 'Nacos, service discovery, circuit breaker' },
  { href: '/docs/best-practices', title: 'Best Practices', desc: 'Performance, security, architecture patterns' },
  { href: '/docs/migration', title: 'Migration Guide', desc: 'Upgrade from v1.x to v2.0' },
];
---

<BaseLayout title="Documentation" description="Bun Server Framework documentation">
  <div class="mx-auto max-w-4xl px-6 py-12">
    <h1 class="mb-4 text-4xl font-bold text-white">Documentation</h1>
    <p class="mb-12 text-zinc-400">Full reference for @dangao/bun-server v2.0.0</p>

    <div class="grid gap-4 sm:grid-cols-2">
      {docSections.map((s) => (
        <a
          href={s.href}
          class:list={[
            'rounded-xl border p-6 transition-all hover:no-underline',
            s.highlight
              ? 'border-brand-800/60 bg-brand-950/20 hover:border-brand-600/60'
              : 'border-zinc-800 bg-zinc-900 hover:border-zinc-700',
          ]}
        >
          <div class="flex items-center gap-2">
            <h2 class="font-semibold text-white">{s.title}</h2>
            {s.highlight && (
              <span class="rounded-full bg-brand-500/20 px-2 py-0.5 text-xs font-semibold text-brand-300">v2.0</span>
            )}
          </div>
          <p class="mt-1 text-sm text-zinc-400">{s.desc}</p>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
