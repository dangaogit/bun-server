---
import BaseLayout from '../../layouts/BaseLayout.astro';
import examplesRegistry from '../../../../../examples/deploy/examples-registry.json';

const groupLabels: Record<string, string> = {
  'quick-start': 'Quick Start',
  'core-features': 'Core Features',
  'official-modules': 'Official Modules',
  'advanced': 'Advanced',
  'real-world': 'Real World',
  'ai': 'AI',
};

const grouped = new Map<string, typeof examplesRegistry>();
for (const example of examplesRegistry.filter((item) => item.enabled && item.exposed)) {
  const current = grouped.get(example.group) ?? [];
  current.push(example);
  grouped.set(example.group, current);
}
---

<BaseLayout title="Examples" description="Bun Server Framework example applications">
  <div class="mx-auto max-w-7xl px-6 py-12">
    <div class="mb-12 text-center">
      <h1 class="text-4xl font-bold text-white">Examples</h1>
      <p class="mt-3 text-zinc-400">
        Learn by example. All examples are in the
        <a href="https://github.com/dangaogit/bun-server/tree/main/examples" class="text-brand-400 hover:text-brand-300">
          GitHub repository
        </a>.
      </p>
    </div>

    <div class="space-y-12">
      {Array.from(grouped.entries()).map(([group, examples]) => (
        <div>
          <div class="mb-4 flex items-center gap-3">
            <img src="/favicon.svg" alt="bun-server logo" class="h-5 w-5" />
            <h2 class="text-xl font-bold text-white">{groupLabels[group] ?? group}</h2>
          </div>
          <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
            {examples.map((ex) => (
              <a
                href={`https://disb-examples-${ex.slug}.dangaogm.com`}
                target="_blank"
                rel="noopener noreferrer"
                class="rounded-xl border border-zinc-800 bg-zinc-900 p-5 transition-colors hover:border-zinc-700"
              >
                <h3 class="font-semibold text-white">{ex.name}</h3>
                <p class="mt-1 text-sm text-zinc-400">{ex.scriptName}</p>
                <code class="mt-2 block font-mono text-xs text-brand-400">
                  {`https://disb-examples-${ex.slug}.dangaogm.com`}
                </code>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</BaseLayout>
