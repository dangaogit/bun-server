---
import BaseLayout from '../../layouts/BaseLayout.astro';

const categories = [
  {
    id: '00-quick-start',
    iconImage: '/favicon.svg',
    label: 'Quick Start',
    desc: 'Get running in 5 minutes',
    examples: [
      { name: 'Hello World', file: '01-hello-world.ts', desc: '5-line HTTP server' },
      { name: 'Basic Routing', file: '02-basic-routing.ts', desc: 'GET/POST/PUT/DELETE routes' },
      { name: 'Dependency Injection', file: '03-dependency-injection.ts', desc: '@Injectable + constructor injection' },
    ],
  },
  {
    id: '02-official-modules',
    label: '📦 Official Modules',
    desc: 'Ready-to-use framework modules',
    examples: [
      { name: 'Auth (JWT + OAuth2)', file: 'auth-app.ts', desc: 'SecurityModule' },
      { name: 'Database + ORM', file: 'orm-app.ts', desc: 'DatabaseModule with Entity/Repository' },
      { name: 'Cache', file: 'cache-app.ts', desc: 'CacheModule with TTL' },
      { name: 'Queue + Cron', file: 'queue-app.ts', desc: 'QueueModule async jobs' },
      { name: 'Events', file: 'events-app.ts', desc: 'EventModule + @OnEvent()' },
      { name: 'Metrics', file: 'metrics-rate-limit-app.ts', desc: 'MetricsModule + RateLimit' },
    ],
  },
  {
    id: '05-ai',
    label: '🤖 AI Modules',
    desc: 'v2.0.0 — 9 official AI modules',
    highlight: true,
    examples: [
      { name: 'Basic Chat', file: '01-basic-chat.ts', desc: 'Multi-provider LLM chat' },
      { name: 'Streaming', file: '02-streaming-chat.ts', desc: 'SSE streaming responses' },
      { name: 'Tool Calling', file: '03-tool-calling.ts', desc: '@AiTool() + function calling loop' },
      { name: 'Conversation Memory', file: '04-conversation-memory.ts', desc: 'Multi-turn history' },
      { name: 'Prompt Templates', file: '05-prompt-templates.ts', desc: '{{variable}} templates + versioning' },
      { name: 'RAG Pipeline', file: '06-rag-pipeline.ts', desc: 'Document → embed → retrieve → answer' },
      { name: 'MCP Server', file: '07-mcp-server.ts', desc: 'Model Context Protocol server' },
      { name: 'AI Guard', file: '08-ai-guard.ts', desc: 'PII + injection + moderation' },
      { name: 'AI Platform MVP', file: 'ai-platform-mvp/', desc: 'Complete Dify-comparable platform' },
    ],
  },
];
---

<BaseLayout title="Examples" description="Bun Server Framework example applications">
  <div class="mx-auto max-w-7xl px-6 py-12">
    <div class="mb-12 text-center">
      <h1 class="text-4xl font-bold text-white">Examples</h1>
      <p class="mt-3 text-zinc-400">
        Learn by example. All examples are in the
        <a href="https://github.com/dangaogit/bun-server/tree/main/examples" class="text-brand-400 hover:text-brand-300">
          GitHub repository
        </a>.
      </p>
    </div>

    <div class="space-y-12">
      {categories.map((cat) => (
        <div>
          <div class:list={[
            'mb-4 flex items-center gap-3',
          ]}>
            {cat.iconImage && <img src={cat.iconImage} alt="bun-server logo" class="h-5 w-5" />}
            <h2 class="text-xl font-bold text-white">{cat.label}</h2>
            {cat.highlight && (
              <span class="rounded-full bg-brand-500/20 px-3 py-0.5 text-xs font-semibold text-brand-300">NEW v2.0</span>
            )}
          </div>
          <p class="mb-4 text-sm text-zinc-400">{cat.desc}</p>
          <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
            {cat.examples.map((ex) => (
              <div class:list={[
                'rounded-xl border p-5 transition-colors',
                cat.highlight
                  ? 'border-brand-900/50 bg-brand-950/20 hover:border-brand-700/50'
                  : 'border-zinc-800 bg-zinc-900 hover:border-zinc-700',
              ]}>
                <h3 class="font-semibold text-white">{ex.name}</h3>
                <p class="mt-1 text-sm text-zinc-400">{ex.desc}</p>
                <code class:list={[
                  'mt-2 block font-mono text-xs',
                  cat.highlight ? 'text-brand-400' : 'text-zinc-500',
                ]}>
                  {cat.id}/{ex.file}
                </code>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</BaseLayout>
