---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title?: string;
  description?: string;
  headings?: Array<{ depth: number; text: string; slug: string }>;
}

const { title, description, headings = [] } = Astro.props;
const isZh = Astro.url.pathname.startsWith('/zh/');
const docsPrefix = isZh ? '/zh/docs' : '/docs';

const docNav = isZh
  ? [
      { label: '快速开始', href: `${docsPrefix}/guide` },
      { label: 'API 参考', href: `${docsPrefix}/api` },
      { label: 'AI 模块', href: `${docsPrefix}/ai` },
      { label: '微服务', href: `${docsPrefix}/microservice` },
      { label: '安全', href: `${docsPrefix}/security` },
      { label: '数据库', href: `${docsPrefix}/database` },
      { label: '测试', href: `${docsPrefix}/testing` },
      { label: '最佳实践', href: `${docsPrefix}/best-practices` },
      { label: '迁移指南', href: `${docsPrefix}/migration` },
    ]
  : [
      { label: 'Getting Started', href: `${docsPrefix}/guide` },
      { label: 'API Reference', href: `${docsPrefix}/api` },
      { label: 'AI Modules', href: `${docsPrefix}/ai` },
      { label: 'Microservices', href: `${docsPrefix}/microservice` },
      { label: 'Security', href: `${docsPrefix}/security` },
      { label: 'Database', href: `${docsPrefix}/database` },
      { label: 'Testing', href: `${docsPrefix}/testing` },
      { label: 'Best Practices', href: `${docsPrefix}/best-practices` },
      { label: 'Migration Guide', href: `${docsPrefix}/migration` },
    ];
---

<BaseLayout title={title} description={description}>
  <div class="mx-auto max-w-7xl px-6 py-8">
    <div class="flex gap-10">
      <!-- Sidebar navigation -->
      <aside class="hidden w-56 shrink-0 lg:block">
        <nav class="sticky top-24 space-y-1">
          <p class="mb-3 text-xs font-semibold uppercase tracking-wider text-zinc-500">
            {isZh ? '文档导航' : 'Documentation'}
          </p>
          {docNav.map((item) => (
            <a
              href={item.href}
              class:list={[
                'block rounded-lg px-3 py-2 text-sm transition-colors',
                Astro.url.pathname.startsWith(item.href)
                  ? 'bg-brand-500/10 text-brand-400 font-medium'
                  : 'text-zinc-400 hover:bg-zinc-800 hover:text-white',
              ]}
            >
              {item.label}
            </a>
          ))}
        </nav>
      </aside>

      <!-- Main content -->
      <div class="min-w-0 flex-1">
        <article class="prose prose-invert prose-zinc max-w-none prose-headings:font-bold">
          <slot />
        </article>
      </div>

      <!-- Table of contents -->
      {headings.length > 0 && (
        <aside class="hidden w-48 shrink-0 xl:block">
          <nav class="sticky top-24 space-y-1">
            <p class="mb-3 text-xs font-semibold uppercase tracking-wider text-zinc-500">
              {isZh ? '本页目录' : 'On this page'}
            </p>
            {headings.filter(h => h.depth <= 3).map((h) => (
              <a
                href={`#${h.slug}`}
                class:list={[
                  'block text-sm text-zinc-400 hover:text-white transition-colors',
                  h.depth === 2 ? 'pl-0' : 'pl-4',
                ]}
              >
                {h.text}
              </a>
            ))}
          </nav>
        </aside>
      )}
    </div>
  </div>
</BaseLayout>

<style is:global>
  .prose :not(pre) > code {
    color: #f9a8d4;
    background: rgba(24, 24, 27, 0.9);
    border: 1px solid rgba(63, 63, 70, 0.8);
    border-radius: 0.375rem;
    padding: 0.1rem 0.35rem;
  }
</style>
