---
const features = [
  {
    iconImage: '/favicon.svg',
    title: 'Bun Runtime',
    description: 'Built on JavaScriptCore. Starts faster, runs leaner, handles more requests per second.',
  },
  {
    icon: '🔧',
    title: 'Decorator-driven DI',
    description: '@Injectable, @Inject, @Module — type-safe dependency injection with constructor-based wiring.',
  },
  {
    icon: '🛣️',
    title: 'Decorator Routing',
    description: '@Controller, @GET, @POST, @Body, @Param — clean, expressive route definitions.',
  },
  {
    icon: '🔒',
    title: 'Security Module',
    description: 'JWT + OAuth2, role-based access control, @Auth() guards — production-ready auth.',
  },
  {
    icon: '🗄️',
    title: 'Database + ORM',
    description: 'SQLite/PostgreSQL/MySQL with Bun SQL, Entity/Repository pattern, @Transactional decorator.',
  },
  {
    icon: '🌐',
    title: 'WebSocket Gateway',
    description: 'Decorator-based WebSocket gateways with @OnOpen, @OnMessage, @OnClose event handlers.',
  },
  {
    icon: '📊',
    title: 'Metrics + Health',
    description: 'Prometheus-compatible metrics, health check indicators, live dashboard UI.',
  },
  {
    icon: '⚡',
    title: 'Platform Adapters',
    description: 'Run on Bun (native speed) or Node.js 22+ — same codebase, auto-detected runtime via six adapter contracts.',
  },
];
---

<section class="py-20">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mb-12 text-center">
      <h2 class="text-3xl font-bold text-white">Everything you need</h2>
      <p class="mt-3 text-zinc-400">Core framework features for building production-ready APIs</p>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {features.map((f) => (
        <div class="rounded-xl border border-zinc-800 bg-zinc-900 p-6 hover:border-zinc-700 transition-colors">
          <div class="mb-3 text-3xl">
            {f.iconImage ? (
              <img src={f.iconImage} alt="bun-server logo" class="h-8 w-8" />
            ) : (
              f.icon
            )}
          </div>
          <h3 class="mb-2 font-semibold text-white">{f.title}</h3>
          <p class="text-sm text-zinc-400">{f.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
