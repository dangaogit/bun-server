---
---

<section class="relative overflow-hidden py-20 sm:py-32">
  <!-- Background gradient -->
  <div class="pointer-events-none absolute inset-0 bg-gradient-to-br from-brand-950/40 via-zinc-950 to-zinc-950" />

  <div class="relative mx-auto max-w-7xl px-6 text-center">
    <!-- Badge -->
    <div class="mb-6 inline-flex items-center rounded-full border border-brand-500/30 bg-brand-500/10 px-4 py-1.5 text-sm font-medium text-brand-300">
      <span class="mr-2">🚀</span>
      v2.0.0 — First-class AI Support
    </div>

    <!-- Heading -->
    <h1 class="mb-6 text-5xl font-extrabold tracking-tight text-white sm:text-6xl lg:text-7xl">
      Build AI Apps<br />
      <span class="text-brand-400">at Bun Speed</span>
    </h1>

    <!-- Subtitle -->
    <p class="mx-auto mb-10 max-w-3xl text-xl text-zinc-400">
      A high-performance decorator-driven DI web framework for Bun Runtime with
      <strong class="text-zinc-200">9 official AI modules</strong> —
      LLM providers, RAG, Tool Calling, MCP server, conversation memory, and more.
    </p>

    <!-- Install command -->
    <div class="mx-auto mb-10 flex max-w-sm items-center justify-between rounded-xl border border-zinc-700 bg-zinc-900 px-5 py-3 font-mono text-sm">
      <span class="text-zinc-400">$</span>
      <span class="flex-1 px-3 text-brand-300">bun add @dangao/bun-server</span>
      <button
        onclick="navigator.clipboard.writeText('bun add @dangao/bun-server')"
        class="text-zinc-500 hover:text-white transition-colors"
        title="Copy"
      >
        📋
      </button>
    </div>

    <!-- CTAs -->
    <div class="flex flex-wrap justify-center gap-4">
      <a
        href="/docs/guide"
        class="rounded-xl bg-brand-500 px-8 py-3 text-base font-semibold text-white hover:bg-brand-400 transition-colors"
      >
        Get Started
      </a>
      <a
        href="/docs/ai"
        class="rounded-xl border border-zinc-700 px-8 py-3 text-base font-semibold text-zinc-200 hover:border-brand-500 hover:text-brand-300 transition-colors"
      >
        AI Modules →
      </a>
      <a
        href="https://github.com/dangaogit/bun-server"
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-xl border border-zinc-700 px-8 py-3 text-base font-semibold text-zinc-400 hover:border-zinc-500 hover:text-white transition-colors"
      >
        GitHub
      </a>
    </div>
  </div>
</section>
