{
  "name": "@dangao/bun-server",
  "version": "3.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "node": "./dist/index.node.mjs",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dangaogit/bun-server.git"
  },
  "keywords": [
    "bun",
    "server",
    "framework",
    "di",
    "logger",
    "middleware"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "src",
    "tests",
    "docs"
  ],
  "author": "dangaogit",
  "license": "MIT",
  "homepage": "https://disb.dangaogm.com",
  "bugs": {
    "url": "https://github.com/dangaogit/bun-server/issues"
  },
  "engines": {
    "bun": ">=1.3.10",
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "test": "bun test",
    "test:bun": "bun test tests/platform/bun",
    "test:node": "vitest run tests/platform/node",
    "test:platform": "bun run test:bun && bun run test:node",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "bundle": "bun build src/index.ts --target=bun --format=esm --outfile=dist/index.js --external reflect-metadata --external @dangao/logsmith --external @dangao/nacos-client --external @vscode/sqlite3",
    "bundle:node": "bun build src/index.ts --target=node --packages=external --outfile=dist/index.node.mjs",
    "dts": "tsc -p tsconfig.build.json",
    "build": "bun run clean && bun run bundle && bun run bundle:node && bun run dts",
    "prepublishOnly": "bun run build",
    "publish:package": "cp -r ../../README.md ../../LICENSE ../../docs . && bun publish --access public && rm -rf ./README.md ./LICENSE ./docs",
    "publish:package:github": "cp -r ../../README.md ../../LICENSE ../../docs . && bun pm pack --access public && npm publish *.tgz --provenance --access public && rm -rf ./README.md ./LICENSE ./docs"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@types/mime-types": "^3.0.1",
    "@types/ws": "^8.18.1",
    "typescript": "catalog:",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "@vscode/sqlite3": "5.1.12-vscode"
  },
  "peerDependenciesMeta": {
    "@vscode/sqlite3": {
      "optional": true
    }
  },
  "dependencies": {
    "@dangao/logsmith": "workspace:*",
    "@dangao/nacos-client": "workspace:*",
    "json5": "^2.2.3",
    "jsonc-parser": "^3.3.1",
    "marked": "^18.0.0",
    "mime-types": "^3.0.2",
    "mysql2": "^3.21.0",
    "postgres": "^3.4.9",
    "reflect-metadata": "catalog:",
    "ws": "^8.20.0"
  }
}