{
  "name": "@dangao/bun-server-project",
  "version": "0.0.1",
  "description": "bun server project",
  "private": true,
  "license": "MIT",
  "scripts": {
    "preinstall": "npx only-allow bun",
    "prepare": "git config core.hooksPath .husky",
    "build": "bun run build:deps && bun run build:server",
    "build:deps": "bun run --filter '@dangao/logsmith' build && bun run --filter '@dangao/nacos-client' build",
    "build:server": "bun run --filter '@dangao/bun-server' build",
    "build:web": "bun run --filter '@dangao/bun-server-web' build",
    "dev:web": "bun run --filter '@dangao/bun-server-web' dev",
    "security:audit": "bun audit",
    "security:check-dev-host": "if rg --line-number --glob '**/package.json' '0\\\\.0\\\\.0\\\\.0' benchmark examples packages; then echo 'Found insecure dev host bindings'; exit 1; else echo 'No insecure dev host bindings found'; fi"
  },
  "keywords": [],
  "author": "dangaogit",
  "workspaces": {
    "packages": [
      "packages/**",
      "examples/**",
      "benchmark/**"
    ],
    "catalog": {
      "@antv/x6": "^3.1.6",
      "@astrojs/mdx": "^5.0.0",
      "@astrojs/tailwind": "^6.0.2",
      "@nestjs/common": "^11.1.16",
      "@nestjs/core": "^11.1.16",
      "@nestjs/platform-express": "^11.1.16",
      "@tailwindcss/typography": "^0.5.19",
      "@types/bun": "^1.3.10",
      "@types/node": "^25.4.0",
      "@types/react": "^19.2.14",
      "@types/react-dom": "^19.2.3",
      "@vitejs/plugin-react": "^5.1.4",
      "astro": "^6.0.3",
      "express": "^5.2.1",
      "highlight.js": "^11.11.1",
      "husky": "^9.1.7",
      "marked": "^17.0.4",
      "marked-highlight": "^2.2.3",
      "react": "^19.2.4",
      "react-dom": "^19.2.4",
      "reflect-metadata": "^0.2.2",
      "rxjs": "^7.8.2",
      "tailwindcss": "^3.4.17",
      "typescript": "^5.9.3",
      "vite": "^7.3.1"
    },
    "catalogs": {}
  },
  "dependencies": {
    "@types/bun": "catalog:"
  },
  "devDependencies": {
    "husky": "catalog:"
  }
}